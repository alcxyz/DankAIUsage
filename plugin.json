{
  "id": "dankAIUsage",
  "name": "AI Usage",
  "description": "Monitor Codex and Claude subscription usage",
  "version": "0.1.0",
  "author": "alcxyz",
  "icon": "monitoring",
  "type": "widget",
  "capabilities": ["dankbar-widget"],
  "component": "./DankAIUsageWidget.qml",
  "settings": "./DankAIUsageSettings.qml",
  "settings_schema": {
    "refreshInterval": {
      "type": "integer",
      "default": 300,
      "minimum": 30,
      "maximum": 1800
    },
    "periodDays": {
      "type": "integer",
      "default": 7,
      "minimum": 1,
      "maximum": 90
    },
    "showCodex": {
      "type": "boolean",
      "default": true
    },
    "showClaude": {
      "type": "boolean",
      "default": true
    },
    "includeCachedTokens": {
      "type": "boolean",
      "default": true
    },
    "compactPill": {
      "type": "boolean",
      "default": false
    },
    "focusWeekly": {
      "type": "boolean",
      "default": false
    }
  },
  "permissions": ["settings_read", "settings_write", "process"],
  "requires": ["dankaiusage", "codex", "claude", "sqlite3"]
}
